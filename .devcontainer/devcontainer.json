{
  "name": "project",
  "remoteUser": "rosdev",
  "build": {
      "dockerfile": "Dockerfile",
      "args": {
          "USERNAME": "rosdev",
          "GID": "1000",
          "UID": "1000"
      }
  },
  "customizations" : {
    "jetbrains" : {
      "backend" : "IntelliJ"
    }
  },
  "workspaceFolder": "/home/rosdev/ros2_ws",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/rosdev/ros2_ws/src,type=bind",
  "mounts": [],
  "runArgs": [
      "--net=host"
  ]
}
