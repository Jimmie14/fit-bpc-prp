<profiles>
  <participant profile_name="default" is_default_profile="true">
    <rtps>
      <name>docker_peer</name>
      <domainId>8</domainId> <!-- Must match ROS_DOMAIN_ID -->
      <builtin>
        <discovery_config>
          <initialPeersList>
            <address>udp://prp-blue:7400</address>
          </initialPeersList>
        </discovery_config>
        <metatrafficUnicastLocatorList>
          <locator>
            <udpv4>prp-blue:7410</udpv4>
          </locator>
        </metatrafficUnicastLocatorList>
      </builtin>
      <participant_listen_ports>
        <port>7410</port>
      </participant_listen_ports>
    </rtps>
  </participant>
</profiles>